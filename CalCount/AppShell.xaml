<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CalCount.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CalCount.View"
    Title="CalCount">

    <!-- Top-level routes (pages are created by these templates) -->
    <ShellContent Route="login" ContentTemplate="{DataTemplate views:LoginPage}" />
    <ShellContent Route="dashboard" ContentTemplate="{DataTemplate views:DashboardPage}" />
    <ShellContent Route="recipes" ContentTemplate="{DataTemplate views:RecipesPage}" />

</Shell>
