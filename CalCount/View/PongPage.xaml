<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalCount.View.PongPage"
             Title="Pong">
    <VerticalStackLayout Padding="12" Spacing="8">
        <Label Text="Pong - two players on same device" HorizontalOptions="Center" />

        <HorizontalStackLayout HorizontalOptions="Center" Spacing="20">
            <Label x:Name="LeftScoreLabel" Text="Left: 0" TextColor="Black" />
            <HorizontalStackLayout Spacing="6">
                <Button Text="Easy" Clicked="OnLevelEasy" />
                <Button Text="Normal" Clicked="OnLevelNormal" />
                <Button Text="Hard" Clicked="OnLevelHard" />
            </HorizontalStackLayout>
            <Label x:Name="RightScoreLabel" Text="Right: 0" TextColor="Black" />
        </HorizontalStackLayout>

        <AbsoluteLayout x:Name="PlayArea" BackgroundColor="Black" HeightRequest="300">
            <BoxView x:Name="LeftPaddle" Color="White" WidthRequest="12" HeightRequest="60" />
            <BoxView x:Name="RightPaddle" Color="White" WidthRequest="12" HeightRequest="60" />
            <BoxView x:Name="Ball" Color="White" WidthRequest="12" HeightRequest="12" />
        </AbsoluteLayout>

        <Grid ColumnSpacing="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <VerticalStackLayout Grid.Column="0" Spacing="6">
                <Label Text="Player 1 (W/S)" HorizontalOptions="Center" />
                <Button Text="W - Up" Clicked="OnP1Up" />
                <Button Text="S - Down" Clicked="OnP1Down" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" Spacing="6">
                <Label Text="Player 2 (Up/Down)" HorizontalOptions="Center" />
                <Button Text="Up" Clicked="OnP2Up" />
                <Button Text="Down" Clicked="OnP2Down" />
            </VerticalStackLayout>
        </Grid>
    </VerticalStackLayout>
</ContentPage>
