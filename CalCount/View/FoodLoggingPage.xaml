<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalCount.View.FoodLoggingPage"
             Title="Log Food"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Search Bar -->
            <Frame BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                   CornerRadius="25"
                   Padding="0"
                   HasShadow="True">
                <HorizontalStackLayout Padding="15" Spacing="10">
                    <Label Text="🔍" FontSize="18" VerticalOptions="Center"/>
                    <Entry Placeholder="Search foods..."
                           Text="{Binding SearchQuery}"
                           HorizontalOptions="FillAndExpand"
                           BackgroundColor="Transparent"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"
                           PlaceholderColor="Gray"/>
                    <Button Text="Search"
                            Command="{Binding SearchFoodsCommand}"
                            Padding="10,0"
                            CornerRadius="20"
                            BackgroundColor="#FF9800"
                            TextColor="White"
                            FontSize="12"/>
                </HorizontalStackLayout>
            </Frame>

            <!-- Categories -->
            <Label Text="Categories" FontSize="14" FontAttributes="Bold"/>
            <CollectionView ItemsSource="{Binding Categories}" SelectionMode="Single" HeightRequest="60">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="#FF9800"
                               CornerRadius="20"
                               Padding="15,8"
                               HasShadow="False">
                            <Label Text="{Binding .}" FontSize="12" TextColor="#FF9800" FontAttributes="Bold"/>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Favorites Section -->
            <Label Text="Favorites" FontSize="14" FontAttributes="Bold"/>
            <CollectionView ItemsSource="{Binding FavoriteFoods}" SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                               CornerRadius="10"
                               Padding="12"
                               Margin="0,5"
                               HasShadow="True">
                            <HorizontalStackLayout Spacing="10">
                                <VerticalStackLayout Spacing="5" HorizontalOptions="FillAndExpand">
                                    <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold"/>
                                    <Label Text="{Binding Nutrition.Calories, StringFormat='Calories: {0:F0}'}" 
                                           FontSize="12" 
                                           TextColor="Gray"/>
                                </VerticalStackLayout>
                                <Button Text="➕" BackgroundColor="#4CAF50" TextColor="White" 
                                        Padding="8" CornerRadius="20" FontSize="14"/>
                            </HorizontalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Search Results -->
            <Label Text="Search Results" FontSize="14" FontAttributes="Bold"/>
            <CollectionView ItemsSource="{Binding SearchResults}" SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                               CornerRadius="10"
                               Padding="12"
                               Margin="0,5"
                               HasShadow="True">
                            <HorizontalStackLayout Spacing="10">
                                <VerticalStackLayout Spacing="5" HorizontalOptions="FillAndExpand">
                                    <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold"/>
                                    <Label Text="{Binding Nutrition.Calories, StringFormat='Calories: {0:F0}'}" 
                                           FontSize="12" 
                                           TextColor="Gray"/>
                                </VerticalStackLayout>
                                <Button Text="➕" BackgroundColor="#4CAF50" TextColor="White" 
                                        Padding="8" CornerRadius="20" FontSize="14"/>
                            </HorizontalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Barcode Scanner -->
            <Button Text="📷 Scan Barcode"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    Padding="15"
                    CornerRadius="25"
                    FontSize="14"
                    FontAttributes="Bold"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
