<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalCount.View.AddFoodPage"
             Title="Add Food/Drink">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">
            <Label Text="{Binding Title}" FontSize="24" HorizontalOptions="Center" />

            <Label Text="Name" />
            <Entry x:Name="NameEntry" Placeholder="e.g., Banana" />

            <Label Text="Calories" />
            <Entry x:Name="CaloriesEntry" Placeholder="e.g., 100" Keyboard="Numeric" />

            <Label Text="Meal" />
            <Picker x:Name="MealPicker">
                <Picker.Items>
                    <x:String>Breakfast</x:String>
                    <x:String>Lunch</x:String>
                    <x:String>Dinner</x:String>
                    <x:String>Snack</x:String>
                </Picker.Items>
            </Picker>

            <Button Text="Save" Clicked="OnSaveClicked" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
