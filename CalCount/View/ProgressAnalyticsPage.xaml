<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalCount.View.ProgressAnalyticsPage"
             Title="Progress Analytics"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Time Period Selector -->
            <HorizontalStackLayout Spacing="10" JustifyContent="SpaceEvenly">
                <Button Text="Week" Padding="20,10" CornerRadius="20" BackgroundColor="#FF9800" TextColor="White"/>
                <Button Text="Month" Padding="20,10" CornerRadius="20" BackgroundColor="#E0E0E0" TextColor="Gray"/>
                <Button Text="Year" Padding="20,10" CornerRadius="20" BackgroundColor="#E0E0E0" TextColor="Gray"/>
            </HorizontalStackLayout>

            <!-- Summary Stats -->
            <Label Text="Weekly Summary" FontSize="16" FontAttributes="Bold"/>
            
            <Frame BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                   CornerRadius="15"
                   Padding="15"
                   HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    
                    <HorizontalStackLayout JustifyContent="SpaceEvenly">
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="Avg Daily" FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center"/>
                            <Label Text="{Binding AverageDailyCalories, StringFormat='{0:F0}'}" 
                                   FontSize="16" 
                                   FontAttributes="Bold"
                                   TextColor="#FF9800"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="Calories" FontSize="11" TextColor="Gray" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="Total Burned" FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center"/>
                            <Label Text="{Binding TotalCaloriesBurned, StringFormat='{0:F0}'}" 
                                   FontSize="16" 
                                   FontAttributes="Bold"
                                   TextColor="#E91E63"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="Calories" FontSize="11" TextColor="Gray" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="Workouts" FontSize="12" TextColor="Gray" HorizontalTextAlignment="Center"/>
                            <Label Text="{Binding WorkoutCount}" 
                                   FontSize="16" 
                                   FontAttributes="Bold"
                                   TextColor="#4CAF50"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="Sessions" FontSize="11" TextColor="Gray" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Macronutrients Average -->
            <Label Text="Average Daily Macros" FontSize="16" FontAttributes="Bold"/>
            
            <Frame BorderColor="{AppThemeBinding Light=#E0E0E0, Dark#333333}"
                   CornerRadius="15"
                   Padding="15"
                   HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    
                    <HorizontalStackLayout JustifyContent="SpaceBetween" Spacing="10">
                        <Label Text="Protein" FontSize="12" VerticalOptions="Center"/>
                        <ProgressBar Progress="0.7" ProgressColor="#FF5722" HorizontalOptions="FillAndExpand"/>
                        <Label Text="{Binding AverageDailyProtein, StringFormat='{0:F1}g'}" 
                               FontSize="12" 
                               FontAttributes="Bold"
                               WidthRequest="50"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout JustifyContent="SpaceBetween" Spacing="10">
                        <Label Text="Carbs" FontSize="12" VerticalOptions="Center"/>
                        <ProgressBar Progress="0.6" ProgressColor="#4CAF50" HorizontalOptions="FillAndExpand"/>
                        <Label Text="{Binding AverageDailyCarbs, StringFormat='{0:F1}g'}" 
                               FontSize="12" 
                               FontAttributes="Bold"
                               WidthRequest="50"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout JustifyContent="SpaceBetween" Spacing="10">
                        <Label Text="Fat" FontSize="12" VerticalOptions="Center"/>
                        <ProgressBar Progress="0.5" ProgressColor="#2196F3" HorizontalOptions="FillAndExpand"/>
                        <Label Text="{Binding AverageDailyFat, StringFormat='{0:F1}g'}" 
                               FontSize="12" 
                               FontAttributes="Bold"
                               WidthRequest="50"/>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Weight Change Estimate -->
            <Frame BorderColor="#FF9800"
                   CornerRadius="15"
                   Padding="15"
                   HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Estimated Weekly Weight Change" FontSize="12" FontAttributes="Bold"/>
                    <HorizontalStackLayout JustifyContent="SpaceBetween">
                        <Label Text="{Binding WeightChange, StringFormat='{0:F2}kg'}" 
                               FontSize="24" 
                               FontAttributes="Bold"
                               TextColor="#FF9800"/>
                        <Label Text="{Binding WeightChange, Converter={StaticResource WeightTrendConverter}}" 
                               FontSize="28" 
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Progress History -->
            <Label Text="Daily Progress" FontSize="16" FontAttributes="Bold" Margin="0,15,0,0"/>
            
            <CollectionView ItemsSource="{Binding ProgressHistory}" SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="{AppThemeBinding Light#E0E0E0, Dark#333333}"
                               CornerRadius="10"
                               Padding="12"
                               Margin="0,5"
                               HasShadow="True">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding Date, StringFormat='{0:dddd, MMM dd}'}" 
                                       FontSize="13" 
                                       FontAttributes="Bold"/>
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="{Binding TotalCaloriesConsumed, StringFormat='Cal: {0:F0}'}" 
                                           FontSize="11" 
                                           TextColor="Gray"/>
                                    <Label Text="{Binding TotalProteinG, StringFormat='P: {0:F1}g'}" 
                                           FontSize="11" 
                                           TextColor="Gray"/>
                                    <Label Text="{Binding WorkoutCount, StringFormat='{0} workout'}" 
                                           FontSize="11" 
                                           TextColor="Gray"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Export Button -->
            <Button Text="📊 Export Report"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    Padding="15"
                    CornerRadius="25"
                    FontSize="14"
                    FontAttributes="Bold"
                    Margin="0,15"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
