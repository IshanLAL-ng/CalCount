<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:CalCount.ViewModel"
    x:Class="CalCount.View.LoginPage"
    Title="Login Page"
    x:DataType="viewmodels:LoginViewModel">

    <ContentPage.BindingContext>
        <viewmodels:LoginViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18" VerticalOptions="Center">

            <Label Text="Welcome" FontSize="24" HorizontalOptions="Center" />

            <Frame Padding="12" HasShadow="True" CornerRadius="8">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Username" />
                    <Entry Text="{Binding Username}" Placeholder="Enter username" />

                    <Label Text="Password" />
                    <Entry Text="{Binding Password}" Placeholder="Enter password" IsPassword="True" />

                    <Button Text="Log in" Command="{Binding LoginCommand}" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
