<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalCount.View.UserProfilePage"
             Title="User Profile"
             BackgroundColor="{AppThemeBinding Light:#FFFFFF, Dark:#1E1E1E}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Profile Header -->
            <Frame BorderColor="{AppThemeBinding Light#E0E0E0, Dark#333333}"
                   CornerRadius="15"
                   Padding="20"
                   HasShadow="True">
                <VerticalStackLayout Spacing="15" HorizontalOptions="Center">
                    <Label Text="👤" FontSize="50" HorizontalOptions="Center"/>
                    <Label Text="{Binding Username}" 
                           FontSize="18" 
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="{Binding Email}" 
                           FontSize="12" 
                           TextColor="Gray"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Basic Info -->
            <Label Text="Basic Information" FontSize="16" FontAttributes="Bold"/>
            
            <VerticalStackLayout Spacing="10">
                <Label Text="Username" FontSize="12" FontAttributes="Bold"/>
                <Entry Text="{Binding Username}"
                       BackgroundColor="{AppThemeBinding Light#F5F5F5, Dark#2A2A2A}"
                       TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="Email" FontSize="12" FontAttributes="Bold"/>
                <Entry Text="{Binding Email}"
                       Keyboard="Email"
                       BackgroundColor="{AppThemeBinding Light#F5F5F5, Dark#2A2A2A}"
                       TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"/>
            </VerticalStackLayout>

            <!-- Physical Stats -->
            <Label Text="Physical Stats" FontSize="16" FontAttributes="Bold" Margin="0,15,0,0"/>

            <HorizontalStackLayout Spacing="15">
                <VerticalStackLayout Spacing="10" HorizontalOptions="FillAndExpand">
                    <Label Text="Age" FontSize="12" FontAttributes="Bold"/>
                    <Entry Text="{Binding Age}"
                           Keyboard="Numeric"
                           BackgroundColor="{AppThemeBinding Light#F5F5F5, Dark#2A2A2A}"
                           TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"/>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10" HorizontalOptions="FillAndExpand">
                    <Label Text="Gender" FontSize="12" FontAttributes="Bold"/>
                    <Picker ItemsSource="{Binding Genders}"
                            SelectedItem="{Binding SelectedGender}"
                            BackgroundColor="{AppThemeBinding Light#F5F5F5, Dark#2A2A2A}"
                            TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="Height (cm)" FontSize="12" FontAttributes="Bold"/>
                <Entry Text="{Binding HeightCm}"
                       Keyboard="Numeric"
                       BackgroundColor="{AppThemeBinding Light#F5F5F5, Dark#2A2A2A}"
                       TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="Weight (kg)" FontSize="12" FontAttributes="Bold"/>
                <Entry Text="{Binding WeightKg}"
                       Keyboard="Numeric"
                       BackgroundColor="{AppThemeBinding Light#F5F5F5, Dark#2A2A2A}"
                       TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="Activity Level" FontSize="12" FontAttributes="Bold"/>
                <Picker ItemsSource="{Binding ActivityLevels}"
                        SelectedItem="{Binding SelectedActivityLevel}"
                        BackgroundColor="{AppThemeBinding Light#F5F5F5, Dark#2A2A2A}"
                        TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"/>
            </VerticalStackLayout>

            <!-- Calculated Stats -->
            <Label Text="Your Stats" FontSize="16" FontAttributes="Bold" Margin="0,15,0,0"/>
            
            <Frame BorderColor="{AppThemeBinding Light#E0E0E0, Dark#333333}"
                   CornerRadius="15"
                   Padding="15"
                   HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    
                    <HorizontalStackLayout JustifyContent="SpaceBetween">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="BMI" FontSize="12" TextColor="Gray"/>
                            <Label Text="{Binding BMI, StringFormat='{0:F1}'}" 
                                   FontSize="16" 
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="3" HorizontalOptions="End">
                            <Label Text="Category" FontSize="12" TextColor="Gray"/>
                            <Label Text="{Binding BMICategory}" 
                                   FontSize="14" 
                                   FontAttributes="Bold"
                                   TextColor="#FF9800"
                                   HorizontalTextAlignment="End"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <BoxView Color="#E0E0E0" HeightRequest="1"/>

                    <HorizontalStackLayout JustifyContent="SpaceBetween">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="BMR" FontSize="12" TextColor="Gray"/>
                            <Label Text="{Binding BMR, StringFormat='{0:F0} cal'}" 
                                   FontSize="14" 
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="3" HorizontalOptions="End">
                            <Label Text="Daily Recommendation" FontSize="12" TextColor="Gray" HorizontalTextAlignment="End"/>
                            <Label Text="{Binding DailyCalorieRecommendation, StringFormat='{0:F0} kcal'}" 
                                   FontSize="14" 
                                   FontAttributes="Bold"
                                   TextColor="#4CAF50"
                                   HorizontalTextAlignment="End"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Health Advice -->
            <Frame BorderColor="{AppThemeBinding Light#E0E0E0, Dark#333333}"
                   CornerRadius="15"
                   Padding="15"
                   HasShadow="True"
                   BorderColor="#FF9800">
                <VerticalStackLayout Spacing="10">
                    <Label Text="💡 BMI Advice" FontSize="12" FontAttributes="Bold"/>
                    <Label Text="{Binding BMIAdvice}" 
                           FontSize="12" 
                           TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="{AppThemeBinding Light#E0E0E0, Dark#333333}"
                   CornerRadius="15"
                   Padding="15"
                   HasShadow="True"
                   BorderColor="#2196F3">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🎯 Calorie Advice" FontSize="12" FontAttributes="Bold"/>
                    <Label Text="{Binding CalorieAdvice}" 
                           FontSize="12" 
                           TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Save Button -->
            <Button Text="Save Profile"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    Padding="15"
                    CornerRadius="25"
                    FontSize="14"
                    FontAttributes="Bold"
                    Margin="0,15"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
