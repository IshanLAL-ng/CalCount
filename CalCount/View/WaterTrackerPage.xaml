<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalCount.View.WaterTrackerPage"
             Title="Water Tracker"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Daily Water Goal Progress -->
            <Frame BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                   CornerRadius="15"
                   Padding="20"
                   HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    <HorizontalStackLayout JustifyContent="SpaceBetween">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Daily Water Goal" FontSize="14" FontAttributes="Bold"/>
                            <Label Text="{Binding WaterGoalMl, StringFormat='{0:F0}ml'}" 
                                   FontSize="18" 
                                   FontAttributes="Bold"
                                   TextColor="#2196F3"/>
                        </VerticalStackLayout>
                        <Label Text="💧" FontSize="50" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <ProgressBar Progress="{Binding WaterProgress, Converter={StaticResource ProgressConverter}}"
                                 ProgressColor="#2196F3"
                                 HeightRequest="25"
                                 CornerRadius="12"/>

                    <HorizontalStackLayout JustifyContent="SpaceBetween">
                        <Label Text="{Binding TotalWaterToday, StringFormat='Consumed: {0:F0}ml'}" 
                               FontSize="12" 
                               TextColor="Gray"/>
                        <Label Text="{Binding WaterStatus}" 
                               FontSize="12" 
                               TextColor="#2196F3"
                               FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Quick Add Buttons -->
            <Label Text="Quick Add" FontSize="14" FontAttributes="Bold"/>
            <HorizontalStackLayout Spacing="10" JustifyContent="SpaceEvenly">
                <Button Text="☕\n250ml"
                        BackgroundColor="#81D4FA"
                        TextColor="#01579B"
                        Padding="20,15"
                        CornerRadius="15"
                        FontSize="12"
                        FontAttributes="Bold"
                        HorizontalOptions="FillAndExpand"/>
                
                <Button Text="🥤\n500ml"
                        BackgroundColor="#4FC3F7"
                        TextColor="#01579B"
                        Padding="20,15"
                        CornerRadius="15"
                        FontSize="12"
                        FontAttributes="Bold"
                        HorizontalOptions="FillAndExpand"/>
                
                <Button Text="🚰\n1000ml"
                        BackgroundColor="#29B6F6"
                        TextColor="White"
                        Padding="20,15"
                        CornerRadius="15"
                        FontSize="12"
                        FontAttributes="Bold"
                        HorizontalOptions="FillAndExpand"/>
            </HorizontalStackLayout>

            <!-- Custom Amount -->
            <Label Text="Custom Amount" FontSize="14" FontAttributes="Bold" Margin="0,15,0,0"/>
            <VerticalStackLayout Spacing="10">
                <HorizontalStackLayout Spacing="10">
                    <Entry Placeholder="Enter amount"
                           Text="{Binding RecentWaterAmount}"
                           Keyboard="Numeric"
                           BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"
                           HorizontalOptions="FillAndExpand"/>
                    <Picker ItemsSource="{Binding WaterUnits}"
                            SelectedItem="{Binding SelectedWaterUnit}"
                            BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"
                            TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"
                            WidthRequest="80"/>
                </HorizontalStackLayout>
                <Button Text="Add Water"
                        BackgroundColor="#2196F3"
                        TextColor="White"
                        Padding="15"
                        CornerRadius="25"
                        FontSize="14"
                        FontAttributes="Bold"/>
            </VerticalStackLayout>

            <!-- Today's Logs -->
            <Label Text="Today's Water Logs" FontSize="14" FontAttributes="Bold" Margin="0,15,0,0"/>
            
            <CollectionView ItemsSource="{Binding TodaysWaterLogs}" SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                               CornerRadius="10"
                               Padding="12"
                               Margin="0,5"
                               HasShadow="True">
                            <HorizontalStackLayout JustifyContent="SpaceBetween">
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="💧" FontSize="20" VerticalOptions="Center"/>
                                    <VerticalStackLayout Spacing="3" JustifyContent="Center">
                                        <Label Text="{Binding AmountMl, StringFormat='{0:F0}ml'}" 
                                               FontSize="14" 
                                               FontAttributes="Bold"/>
                                        <Label Text="{Binding LoggedDateTime, StringFormat='{0:HH:mm:ss}'}" 
                                               FontSize="11" 
                                               TextColor="Gray"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                                <Button Text="✕" BackgroundColor="#FF5252" TextColor="White" 
                                        Padding="8" CornerRadius="20" FontSize="14" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
