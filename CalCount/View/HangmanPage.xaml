<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalCount.View.HangmanPage"
             Title="Hangman">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label x:Name="WordLabel" FontSize="24" HorizontalOptions="Center" />
            <Label x:Name="StatusLabel" FontSize="14" HorizontalOptions="Center" />
            <Grid x:Name="LettersGrid" ColumnSpacing="6" RowSpacing="6" />
            <Button Text="New Word" Clicked="OnNewWordClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
