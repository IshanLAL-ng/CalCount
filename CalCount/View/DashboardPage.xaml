<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalCount.View.DashboardPage"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18" VerticalOptions="Start">

            <!-- Top action buttons: Recipes, Add Food/Drinks, Settings -->
            <HorizontalStackLayout Spacing="12" HorizontalOptions="Fill" VerticalOptions="Start">
                <Button Text="Recipes"
                        Clicked="OnRecipesClicked"
                        BackgroundColor="#ECEFF1"
                        TextColor="#333333"
                        CornerRadius="8"
                        Padding="12,8"
                        HorizontalOptions="StartAndExpand" />

                <Button Text="Add Food/Drinks"
                        Clicked="OnAddFoodClicked"
                        BackgroundColor="#ECEFF1"
                        TextColor="#333333"
                        CornerRadius="8"
                        Padding="12,8"
                        HorizontalOptions="CenterAndExpand" />

                <Button Text="Settings"
                        Clicked="OnSettingsClicked"
                        BackgroundColor="#ECEFF1"
                        TextColor="#333333"
                        CornerRadius="8"
                        Padding="12,8"
                        HorizontalOptions="EndAndExpand" />
            </HorizontalStackLayout>

            <Label Text="{Binding Title}" FontSize="24" HorizontalOptions="Center" />
            <Label x:Name="WelcomeLabel" Text="Welcome!" HorizontalOptions="Center" />

            <HorizontalStackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Fill">
                <Label Text="BMR:" FontAttributes="Bold" VerticalTextAlignment="Center" />
                <Label x:Name="BMRValue" Text="--" FontAttributes="Bold" VerticalTextAlignment="Center" HorizontalOptions="EndAndExpand" />
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Fill">
                <Label Text="Recommended Calories:" FontAttributes="Bold" VerticalTextAlignment="Center" />
                <Label x:Name="RecommendedCaloriesValue" Text="--" FontAttributes="Bold" VerticalTextAlignment="Center" HorizontalOptions="EndAndExpand" />
            </HorizontalStackLayout>
            <GraphicsView x:Name="MealBarChart" HeightRequest="240" HorizontalOptions="Fill" Margin="0,0,0,6" />

            <Label Text="Daily Calories (Last 7 days)" FontAttributes="Bold" />
            <GraphicsView x:Name="HistoryBarChart" HeightRequest="240" HorizontalOptions="Fill" Margin="0,0,0,6" />

            <Label Text="Macro Breakdown (Recommended)" FontAttributes="Bold" />
            <GraphicsView x:Name="MacroPieChart" HeightRequest="240" HorizontalOptions="Fill" Margin="0,0,0,6" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
