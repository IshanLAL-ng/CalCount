<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalCount.View.DashboardPage"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18" VerticalOptions="Start">

            <!-- Top action buttons: Recipes, Add Food/Drinks, Settings -->
            <HorizontalStackLayout Spacing="12" HorizontalOptions="Fill" VerticalOptions="Start">
                <Button Text="Recipes"
                        Clicked="OnRecipesClicked"
                        BackgroundColor="#ECEFF1"
                        TextColor="#333333"
                        CornerRadius="8"
                        Padding="12,8"
                        HorizontalOptions="StartAndExpand" />

                <Button Text="Add Food/Drinks"
                        Clicked="OnAddFoodClicked"
                        BackgroundColor="#ECEFF1"
                        TextColor="#333333"
                        CornerRadius="8"
                        Padding="12,8"
                        HorizontalOptions="CenterAndExpand" />

                <Button Text="Settings"
                        Clicked="OnSettingsClicked"
                        BackgroundColor="#ECEFF1"
                        TextColor="#333333"
                        CornerRadius="8"
                        Padding="12,8"
                        HorizontalOptions="EndAndExpand" />
            </HorizontalStackLayout>

            <Label Text="Dashboard" FontSize="24" HorizontalOptions="Center" />
            <Label x:Name="WelcomeLabel" Text="Welcome!" HorizontalOptions="Center" />

            <Label Text="Calories by Meal" FontAttributes="Bold" />
            <GraphicsView x:Name="MealBarChart" HeightRequest="180" HorizontalOptions="Fill" />

            <Label Text="Daily Calories (Last 7 days)" FontAttributes="Bold" />
            <GraphicsView x:Name="HistoryBarChart" HeightRequest="180" HorizontalOptions="Fill" />

            <Label Text="Macro Breakdown" FontAttributes="Bold" />
            <GraphicsView x:Name="MacroPieChart" HeightRequest="200" HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
