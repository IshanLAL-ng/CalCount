<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalCount.View.GamesPage"
             Title="Games">
    <VerticalStackLayout Padding="20" Spacing="18">
        <Label Text="Choose a game" FontSize="24" HorizontalOptions="Center" />
        <Button Text="1) Hangman" Clicked="OnHangmanClicked" />
        <Button Text="2) Pong" Clicked="OnPongClicked" />
        <Button Text="3) Tic Tac Toe" Clicked="OnTicTacToeClicked" />
    </VerticalStackLayout>
</ContentPage>
