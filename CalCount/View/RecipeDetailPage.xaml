<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalCount.View.RecipeDetailPage"
             Title="Recipe Detail"
             BackgroundColor="#fafafa">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">

            <!-- Read-only title -->
            <Label Text="{Binding TitleText}" FontSize="20" FontAttributes="Bold" TextColor="#333" />

            <!-- Recipe image with frame -->
            <Frame HasShadow="True" CornerRadius="12" Padding="0" BorderColor="#e0e0e0" HorizontalOptions="Center">
                <Image Source="{Binding ImageUrl}" 
                       WidthRequest="280" 
                       HeightRequest="200" 
                       Aspect="AspectFill"
                       Margin="0"/>
            </Frame>

            <!-- Ingredients section -->
            <Label Text="Ingredients" FontAttributes="Bold" FontSize="16" TextColor="#333" />
            <Frame BorderColor="#f0f0f0" CornerRadius="8" Padding="12" HasShadow="False">
                <Label Text="{Binding Ingredients}" 
                       LineBreakMode="WordWrap"
                       TextColor="#555"
                       FontSize="13" />
            </Frame>

            <!-- Instructions section -->
            <Label Text="Instructions" FontAttributes="Bold" FontSize="16" TextColor="#333" />
            <Frame BorderColor="#f0f0f0" CornerRadius="8" Padding="12" HasShadow="False">
                <Label Text="{Binding Instructions}" 
                       LineBreakMode="WordWrap"
                       TextColor="#555"
                       FontSize="13" />
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
