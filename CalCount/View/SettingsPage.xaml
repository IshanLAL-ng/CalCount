<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalCount.View.SettingsPage"
             Title="Settings"
             BackgroundColor="{AppThemeBinding Light:#FFFFFF, Dark:#1E1E1E}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Theme Settings -->
            <Label Text="Appearance" FontSize="16" FontAttributes="Bold"/>
            
            <Frame BorderColor="{AppThemeBinding Light#E0E0E0, Dark#333333}"
                   CornerRadius="12"
                   Padding="15"
                   HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    <HorizontalStackLayout JustifyContent="SpaceBetween">
                        <Label Text="Dark Mode" FontSize="14" VerticalOptions="Center"/>
                        <Switch IsToggled="{Binding DarkModeEnabled}" OnColor="#FF9800"/>
                    </HorizontalStackLayout>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Theme" FontSize="12" FontAttributes="Bold"/>
                        <Picker ItemsSource="{Binding Themes}"
                                SelectedItem="{Binding SelectedTheme}"
                                BackgroundColor="{AppThemeBinding Light#F5F5F5, Dark#2A2A2A}"
                                TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Notification Settings -->
            <Label Text="Notifications &amp; Reminders" FontSize="16" FontAttributes="Bold" Margin="0,15,0,0"/>
            
            <Frame BorderColor="{AppThemeBinding Light#E0E0E0, Dark#333333}"
                   CornerRadius="12"
                   Padding="15"
                   HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    
                    <HorizontalStackLayout JustifyContent="SpaceBetween">
                        <Label Text="Enable Notifications" FontSize="14" VerticalOptions="Center"/>
                        <Switch IsToggled="{Binding NotificationsEnabled}" OnColor="#FF9800"/>
                    </HorizontalStackLayout>

                    <BoxView Color="#E0E0E0" HeightRequest="1"/>

                    <!-- Meal Reminders -->
                    <Label Text="Meal Reminders" FontSize="13" FontAttributes="Bold"/>

                    <HorizontalStackLayout JustifyContent="SpaceBetween">
                        <Label Text="Breakfast Reminder" FontSize="12" VerticalOptions="Center"/>
                        <Switch IsToggled="{Binding ReminderBreakfast}" OnColor="#FF9800"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10" IsEnabled="{Binding ReminderBreakfast}">
                        <Label Text="Time:" FontSize="11" VerticalOptions="Center"/>
                        <Entry Text="{Binding BreakfastTime}" 
                               Placeholder="HH:mm"
                               BackgroundColor="{AppThemeBinding Light#F5F5F5, Dark#2A2A2A}"
                               TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"
                               WidthRequest="100"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout JustifyContent="SpaceBetween">
                        <Label Text="Lunch Reminder" FontSize="12" VerticalOptions="Center"/>
                        <Switch IsToggled="{Binding ReminderLunch}" OnColor="#FF9800"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10" IsEnabled="{Binding ReminderLunch}">
                        <Label Text="Time:" FontSize="11" VerticalOptions="Center"/>
                        <Entry Text="{Binding LunchTime}" 
                               Placeholder="HH:mm"
                               BackgroundColor="{AppThemeBinding Light#F5F5F5, Dark#2A2A2A}"
                               TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"
                               WidthRequest="100"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout JustifyContent="SpaceBetween">
                        <Label Text="Dinner Reminder" FontSize="12" VerticalOptions="Center"/>
                        <Switch IsToggled="{Binding ReminderDinner}" OnColor="#FF9800"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10" IsEnabled="{Binding ReminderDinner}">
                        <Label Text="Time:" FontSize="11" VerticalOptions="Center"/>
                        <Entry Text="{Binding DinnerTime}" 
                               Placeholder="HH:mm"
                               BackgroundColor="{AppThemeBinding Light#F5F5F5, Dark#2A2A2A}"
                               TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"
                               WidthRequest="100"/>
                    </HorizontalStackLayout>

                    <BoxView Color="#E0E0E0" HeightRequest="1"/>

                    <!-- Water Reminder -->
                    <Label Text="Hydration Reminders" FontSize="13" FontAttributes="Bold"/>

                    <HorizontalStackLayout JustifyContent="SpaceBetween">
                        <Label Text="Water Reminder" FontSize="12" VerticalOptions="Center"/>
                        <Switch IsToggled="{Binding ReminderWater}" OnColor="#FF9800"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10" IsEnabled="{Binding ReminderWater}">
                        <Label Text="Time:" FontSize="11" VerticalOptions="Center"/>
                        <Entry Text="{Binding WaterReminderTime}" 
                               Placeholder="HH:mm"
                               BackgroundColor="{AppThemeBinding Light#F5F5F5, Dark#2A2A2A}"
                               TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"
                               WidthRequest="100"/>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Action Buttons -->
            <Button Text="Save Settings"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    Padding="15"
                    CornerRadius="25"
                    FontSize="14"
                    FontAttributes="Bold"
                    Margin="0,15"/>

            <Button Text="Reset to Defaults"
                    BackgroundColor="#FF5252"
                    TextColor="White"
                    Padding="15"
                    CornerRadius="25"
                    FontSize="14"
                    FontAttributes="Bold"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
