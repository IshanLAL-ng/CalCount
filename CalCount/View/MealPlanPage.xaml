<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalCount.View.MealPlanPage"
             Title="Meal Plans"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Meal Plan Form -->
            <Label Text="Create Meal Plan" FontSize="18" FontAttributes="Bold"/>

            <VerticalStackLayout Spacing="10">
                <Label Text="Plan Name" FontSize="12" FontAttributes="Bold"/>
                <Entry Placeholder="e.g., Weekly Keto Plan"
                       Text="{Binding MealPlanName}"
                       BackgroundColor="{AppThemeBinding Light#F5F5F5, Dark#2A2A2A}"
                       TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"/>
            </VerticalStackLayout>

            <!-- Predefined Plans -->
            <Label Text="Quick Start Plans" FontSize="12" FontAttributes="Bold" Margin="0,10,0,0"/>
            <CollectionView ItemsSource="{Binding PredefinedPlans}" SelectionMode="Single" HeightRequest="100">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="#FF9800"
                               CornerRadius="12"
                               Padding="15,10"
                               HasShadow="False">
                            <Label Text="{Binding .}" FontSize="12" TextColor="#FF9800" FontAttributes="Bold"/>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Daily Targets -->
            <Label Text="Daily Targets" FontSize="14" FontAttributes="Bold" Margin="0,15,0,0"/>

            <VerticalStackLayout Spacing="10">
                <Label Text="Calories" FontSize="12" FontAttributes="Bold"/>
                <Slider Value="{Binding DailyCalorieTarget}" Minimum="1200" Maximum="3500" StepValue="50"/>
                <Label Text="{Binding DailyCalorieTarget, StringFormat='{0:F0} kcal'}" 
                       FontSize="14" 
                       FontAttributes="Bold"
                       TextColor="#FF9800"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="Protein" FontSize="12" FontAttributes="Bold"/>
                <Slider Value="{Binding DailyProteinTarget}" Minimum="20" Maximum="300" StepValue="5"/>
                <Label Text="{Binding DailyProteinTarget, StringFormat='{0:F1}g'}" 
                       FontSize="14" 
                       FontAttributes="Bold"
                       TextColor="#FF5722"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="Carbs" FontSize="12" FontAttributes="Bold"/>
                <Slider Value="{Binding DailyCarbsTarget}" Minimum="20" Maximum="400" StepValue="5"/>
                <Label Text="{Binding DailyCarbsTarget, StringFormat='{0:F1}g'}" 
                       FontSize="14" 
                       FontAttributes="Bold"
                       TextColor="#4CAF50"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="Fat" FontSize="12" FontAttributes="Bold"/>
                <Slider Value="{Binding DailyFatTarget}" Minimum="15" Maximum="150" StepValue="2"/>
                <Label Text="{Binding DailyFatTarget, StringFormat='{0:F1}g'}" 
                       FontSize="14" 
                       FontAttributes="Bold"
                       TextColor="#2196F3"/>
            </VerticalStackLayout>

            <!-- Date Range -->
            <Label Text="Plan Duration" FontSize="14" FontAttributes="Bold" Margin="0,15,0,0"/>
            
            <VerticalStackLayout Spacing="10">
                <Label Text="Start Date" FontSize="12" FontAttributes="Bold"/>
                <DatePicker Date="{Binding StartDate}" BackgroundColor="{AppThemeBinding Light#F5F5F5, Dark#2A2A2A}"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="End Date (Optional)" FontSize="12" FontAttributes="Bold"/>
                <DatePicker Date="{Binding EndDate}" BackgroundColor="{AppThemeBinding Light#F5F5F5, Dark#2A2A2A}"/>
            </VerticalStackLayout>

            <!-- Active Toggle -->
            <CheckBox IsChecked="{Binding IsActive}" Title="Make this plan active" Margin="0,10"/>

            <!-- Create Button -->
            <Button Text="Create Meal Plan"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    Padding="15"
                    CornerRadius="25"
                    FontSize="14"
                    FontAttributes="Bold"/>

            <!-- Your Plans -->
            <Label Text="Your Meal Plans" FontSize="14" FontAttributes="Bold" Margin="0,20,0,0"/>
            
            <CollectionView ItemsSource="{Binding MealPlans}" SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="{AppThemeBinding Light#E0E0E0, Dark#333333}"
                               CornerRadius="12"
                               Padding="15"
                               Margin="0,8"
                               HasShadow="True">
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout HorizontalOptions="FillAndExpand">
                                    <Label Text="{Binding Name}" 
                                           FontSize="15" 
                                           FontAttributes="Bold"/>
                                    <Label Text="{Binding IsActive, StringFormat='{0:Active}'}" 
                                           FontSize="11" 
                                           TextColor="#4CAF50"
                                           FontAttributes="Bold"/>
                                </HorizontalStackLayout>
                                
                                <Label Text="{Binding StartDate, StringFormat='Started: {0:MMM dd}'}" 
                                       FontSize="12" 
                                       TextColor="Gray"/>
                                
                                <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                    <Button Text="✎ Edit" 
                                            BackgroundColor="#2196F3" 
                                            TextColor="White"
                                            Padding="8,4"
                                            CornerRadius="15"
                                            FontSize="11"/>
                                    <Button Text="✕" 
                                            BackgroundColor="#FF5252" 
                                            TextColor="White"
                                            Padding="8,4"
                                            CornerRadius="15"
                                            FontSize="11"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
