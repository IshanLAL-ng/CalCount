<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalCount.View.RecipesPage"
             Title="Recipes"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}">

    <VerticalStackLayout Padding="0" Spacing="0">
        
        <!-- Search and Filter Bar -->
        <VerticalStackLayout Padding="20,15,20,10" Spacing="10">
            <Frame BorderColor="{AppThemeBinding Light#E0E0E0, Dark#333333}"
                   CornerRadius="25"
                   Padding="0"
                   HasShadow="True">
                <HorizontalStackLayout Padding="15" Spacing="10">
                    <Label Text="🔍" FontSize="18" VerticalOptions="Center"/>
                    <Entry Placeholder="Search recipes..."
                           Text="{Binding SearchQuery}"
                           HorizontalOptions="FillAndExpand"
                           BackgroundColor="Transparent"
                           TextColor="{AppThemeBinding Light#333333, Dark#FFFFFF}"
                           PlaceholderColor="Gray"/>
                </HorizontalStackLayout>
            </Frame>

            <!-- Recipe Type Filter -->
            <CollectionView ItemsSource="{Binding RecipeTypes}" SelectionMode="Single" HeightRequest="50">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="#FF9800"
                               CornerRadius="20"
                               Padding="12,6"
                               HasShadow="False">
                            <Label Text="{Binding .}" FontSize="11" TextColor="#FF9800" FontAttributes="Bold"/>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <!-- Recipes List -->
        <ScrollView>
            <VerticalStackLayout Padding="20,10" Spacing="10">
                
                <Label Text="Your Recipes" FontSize="14" FontAttributes="Bold"/>
                
                <CollectionView ItemsSource="{Binding SearchResults}" SelectionMode="Single">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BorderColor="{AppThemeBinding Light#E0E0E0, Dark#333333}"
                                   CornerRadius="12"
                                   Padding="15"
                                   Margin="0,8"
                                   HasShadow="True">
                                <VerticalStackLayout Spacing="10">
                                    <HorizontalStackLayout HorizontalOptions="FillAndExpand">
                                        <VerticalStackLayout Spacing="5" HorizontalOptions="FillAndExpand">
                                            <Label Text="{Binding Name}" 
                                                   FontSize="15" 
                                                   FontAttributes="Bold"/>
                                            <Label Text="{Binding Type}" 
                                                   FontSize="12" 
                                                   TextColor="Gray"/>
                                        </VerticalStackLayout>
                                        <Label Text="🍳" FontSize="28" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                    
                                    <HorizontalStackLayout Spacing="15">
                                        <Label Text="{Binding PrepTimeMinutes, StringFormat='Prep: {0}m'}" 
                                               FontSize="11" 
                                               TextColor="Gray"/>
                                        <Label Text="{Binding CookTimeMinutes, StringFormat='Cook: {0}m'}" 
                                               FontSize="11" 
                                               TextColor="Gray"/>
                                        <Label Text="{Binding Servings, StringFormat='{0} servings'}" 
                                               FontSize="11" 
                                               TextColor="Gray"/>
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                        <Button Text="👁️ View" 
                                                BackgroundColor="#2196F3" 
                                                TextColor="White"
                                                Padding="8,4"
                                                CornerRadius="15"
                                                FontSize="11"/>
                                        <Button Text="➕ Use" 
                                                BackgroundColor="#4CAF50" 
                                                TextColor="White"
                                                Padding="8,4"
                                                CornerRadius="15"
                                                FontSize="11"/>
                                        <Button Text="✕" 
                                                BackgroundColor="#FF5252" 
                                                TextColor="White"
                                                Padding="8,4"
                                                CornerRadius="15"
                                                FontSize="11"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

    </VerticalStackLayout>

    <!-- Floating Action Button for New Recipe -->
    <Button Text="+"
            FontSize="32"
            TextColor="White"
            BackgroundColor="#FF9800"
            CornerRadius="35"
            HeightRequest="70"
            WidthRequest="70"
            Padding="0"
            Margin="20"
            HorizontalOptions="End"
            VerticalOptions="End"/>

</ContentPage>
