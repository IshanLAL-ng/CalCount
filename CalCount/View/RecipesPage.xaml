<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:CalCount.ViewModel"
    x:Class="CalCount.View.RecipesPage"
    x:DataType="viewmodels:RecipesViewModel"
    Title="Recipes">

    <ContentPage.BindingContext>
        <viewmodels:RecipesViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18" VerticalOptions="Center">
            <Label Text="{Binding Title}" FontSize="24" HorizontalOptions="Center" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="12">
                <Button Text="Savory" Command="{Binding OpenSavoryCommand}" />
                <Button Text="Sweet" Command="{Binding OpenSweetCommand}" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
