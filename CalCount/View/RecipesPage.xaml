<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalCount.View.RecipesPage"
             Title="Recipes">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18" VerticalOptions="Center">
            <Label Text="Recipes" FontSize="24" HorizontalOptions="Center" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="12">
                <Button Text="Savory" x:Name="SavoryBtn" />
                <Button Text="Sweet" x:Name="SweetBtn" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
